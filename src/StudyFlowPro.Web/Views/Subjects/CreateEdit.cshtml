@model SubjectFormViewModel
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Subject" : "Create Subject";
}

<section class="form-shell">
    <article class="form-card">
        <div class="panel-header">
            <div>
                <span class="section-tag">Subject</span>
                <h1>@(isEdit ? "Update subject details" : "Create a new subject")</h1>
            </div>
            <a class="text-link" asp-action="Index">Back to subjects</a>
        </div>

        <form method="post" class="app-form">
            @Html.AntiForgeryToken()
            @if (isEdit)
            {
                <input asp-for="Id" type="hidden" />
            }

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Software Engineering" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Code"></label>
                    <input asp-for="Code" class="form-control" placeholder="e.g. SE401" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="AccentColor"></label>
                    <div class="color-input-row">
                        <input asp-for="AccentColor" class="form-control form-control-color" type="color" />
                        <input asp-for="AccentColor" class="form-control" placeholder="#2563EB" />
                    </div>
                    <span asp-validation-for="AccentColor" class="text-danger"></span>
                </div>

                <div class="form-field form-field-full">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Add a short overview to describe what this subject covers."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <a class="outline-button" asp-action="Index">Cancel</a>
                <button type="submit" class="primary-button">@(isEdit ? "Save changes" : "Create subject")</button>
            </div>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
